{
    "name": "antigravity-agent",
    "displayName": "Antigravity Agent",
    "description": "Manage your Antigravity accounts directly from VS Code",
    "version": "1.7.2",
    "icon": "images/icon.png",
    "type": "module",
    "publisher": "MonchiLin",
    "repository": {
        "type": "git",
        "url": "https://github.com/MonchiLin/antigravity-agent"
    },
    "engines": {
        "vscode": "^1.104.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension/extension.js",
    "contributes": {
        "configuration": {
            "title": "Antigravity Agent",
            "properties": {
                "antigravity-agent.privacy": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable Privacy Mode (masks email in status bar)."
                },
                "antigravity-agent.autoPilot": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable Auto Pilot mode."
                },
                "antigravity-agent.showAccount": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show the current account in the StatusBar.",
                    "title": "Show Account"
                }
            }
        },
        "icons": {
            "antigravity-logo": {
                "description": "Antigravity Agent Logo",
                "default": {
                    "fontPath": "./images/icon-outline.svg",
                    "fontCharacter": "\\E001"
                }
            }
        },
        "commands": [
            {
                "command": "antigravity.agent.open_dashboard",
                "title": "Open Antigravity Agent Dashboard"
            }
        ]
    },
    "scripts": {
        "dev": "npm run build:extension -- --watch",
        "build": "npm run build:extension && npm run build:webview",
        "build:extension": "vite build --config vite.extension.config.ts",
        "build:webview": "vite build --config vite.webview.config.ts",
        "watch": "npm run build:extension -- --watch",
        "check:extension": "tsc --noEmit -p tsconfig.json",
        "check:webview": "tsc --noEmit -p tsconfig.webview.json",
        "check": "npm run check:extension && npm run check:webview",
        "package": "npm run check && npm run build",
        "vscode:prepublish": "npm run package",
        "vsix": "npx vsce package --no-dependencies",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "@tailwindcss/vite": "^4.2.1",
        "@types/glob": "^9.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.3.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/vscode": "^1.109.0",
        "@vitejs/plugin-react": "^5.1.4",
        "@vscode/test-electron": "^2.5.2",
        "autoprefixer": "^10.4.27",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    },
    "dependencies": {
        "@vscode/codicons": "^0.0.44",
        "@vscode/webview-ui-toolkit": "^1.4.0",
        "dayjs": "^1.11.19",
        "i18next": "^25.8.14",
        "i18next-browser-languagedetector": "^8.2.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-i18next": "^16.5.6",
        "zustand": "^5.0.11"
    }
}
